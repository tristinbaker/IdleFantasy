    <!-- ===== Dungeon names and descriptions ===== -->
    <string name="dungeon_imp_cavern_name">İmp Mağarası</string>
    <string name="dungeon_imp_cavern_desc">Yaramaz implerle dolu sığ bir mağara. Yeni başlayanlar için mükemmel!</string>
    <string name="dungeon_goblin_cave_name">Goblin Mağarası</string>
    <string name="dungeon_goblin_cave_desc">Goblinler ve dev sıçanlarla dolu karanlık bir mağara. Yeni maceracıların antrenman yapması için iyi bir yer.</string>
    <string name="dungeon_spider_den_name">Örümcek İni</string>
    <string name="dungeon_spider_den_desc">Zehirli örümceklerin kaynadığı ağlarla dolu bir mağara. Panzehir getirin!</string>
    <string name="dungeon_bandit_camp_name">Haydut Kampı</string>
    <string name="dungeon_bandit_camp_desc">Vahşi doğada hırsızlar ve düzenbazların saklandığı bir sığınak. Kesene dikkat et!</string>
    <string name="dungeon_undead_crypt_name">Ölümsüz Mahzeni</string>
    <string name="dungeon_undead_crypt_desc">Ölülerin dinlenmeyi reddettiği kadim bir mezarlık. Kara büyüye dikkat!</string>
    <string name="dungeon_fortress_ruins_name">Kale Harabeleri</string>
    <string name="dungeon_fortress_ruins_desc">Şövalyeler ve askerler tarafından korunan kadim bir kalenin dökülen kalıntıları.</string>
    <string name="dungeon_orc_stronghold_name">Ork Kalesi</string>
    <string name="dungeon_orc_stronghold_desc">Dağların derinliklerinde tahkim edilmiş bir ork yerleşimi. Sadece cesurlar girmeye cüret edebilir.</string>
    <string name="dungeon_volcanic_depths_name">Volkanik Derinlikler</string>
    <string name="dungeon_volcanic_depths_desc">Cehennem tazıları ve küçük şeytanların yaşadığı kavurucu bir mağara. Sıcaklık dayanılmaz!</string>
    <string name="dungeon_dragon_lair_name">Ejderha İni</string>
    <string name="dungeon_dragon_lair_desc">Yeşil ejderhaların efsanevi yuvası. Bu zorluktan sadece usta savaşçılar sağ çıkabilir.</string>
    <string name="dungeon_farm_name">Çiftlik</string>
    <string name="dungeon_farm_desc">Çiftlik hayvanlarının bulunduğu huzurlu bir çiftlik. Yiyecek toplamak isteyen yeni başlayanlar için harika!</string>
    <string name="dungeon_infernal_stronghold_name">Cehennem Kalesi</string>
    <string name="dungeon_infernal_stronghold_desc">Şeytanlar ve cehennem tazıları tarafından yönetilen ateş ve kükürt kalesi. Sadece sıcaklık bile hazırlıksız olanları öldürebilir.</string>
    <string name="dungeon_ancient_temple_name">Kadim Tapınak</string>
    <string name="dungeon_ancient_temple_desc">Diyardaki en güçlü yaratıklar tarafından korunan kadim bir tapınak. Sadece en güçlü savaşçılar girmeye cüret edebilir.</string>

