    <!-- ===== Dungeon names and descriptions ===== -->
    <string name="dungeon_imp_cavern_name">インプの洞窟</string>
    <string name="dungeon_imp_cavern_desc">いたずら好きなインプでいっぱいの浅い洞窟。初心者に最適です！</string>
    <string name="dungeon_goblin_cave_name">ゴブリンの洞窟</string>
    <string name="dungeon_goblin_cave_desc">ゴブリンと巨大ネズミがはびこる暗い洞窟。駆け出しの冒険者が訓練するのに適した場所です。</string>
    <string name="dungeon_spider_den_name">クモの巣窟</string>
    <string name="dungeon_spider_den_desc">毒グモが這い回る、蜘蛛の巣に覆われた洞窟。解毒薬を持参してください！</string>
    <string name="dungeon_bandit_camp_name">山賊のキャンプ</string>
    <string name="dungeon_bandit_camp_desc">荒野にある泥棒やならず者たちの隠れ家。財布を盗まれないよう気をつけましょう！</string>
    <string name="dungeon_undead_crypt_name">不死者の地下墓地</string>
    <string name="dungeon_undead_crypt_desc">死者が眠ることを拒む古代の埋葬地。闇の魔法に注意してください！</string>
    <string name="dungeon_fortress_ruins_name">要塞の廃墟</string>
    <string name="dungeon_fortress_ruins_desc">古代の城の崩れかけた遺跡。現在は騎士や兵士たちによって守られています。</string>
    <string name="dungeon_orc_stronghold_name">オークの砦</string>
    <string name="dungeon_orc_stronghold_desc">山の奥深くにある要塞化されたオークの集落。勇敢な者だけが立ち入ることを許されます。</string>
    <string name="dungeon_volcanic_depths_name">火山深部</string>
    <string name="dungeon_volcanic_depths_desc">ヘルハウンドやレッサーデーモンが生息する、焼けつくような洞窟。耐えがたいほどの暑さです！</string>
    <string name="dungeon_dragon_lair_name">竜の巣</string>
    <string name="dungeon_dragon_lair_desc">グリーンドラゴンの伝説的な住処。熟練の戦士だけがこの試練を生き延びることができます。</string>
    <string name="dungeon_farm_name">農場</string>
    <string name="dungeon_farm_desc">家畜のいる平和な農場。食料を集めたい初心者に最適です！</string>
    <string name="dungeon_infernal_stronghold_name">地獄の要塞</string>
    <string name="dungeon_infernal_stronghold_desc">デーモンとヘルハウンドが支配する、炎と硫黄の要塞。十分な準備がない者は、その暑さだけで命を落とすでしょう。</string>
    <string name="dungeon_ancient_temple_name">古代の神殿</string>
    <string name="dungeon_ancient_temple_desc">この世で最も強力なクリーチャーたちによって守られている古代の神殿。最強の戦士だけが立ち入る勇気を持ちます。</string>

    <!-- ===== Solo boss names (raid bosses retargeted for solo play) ===== -->
