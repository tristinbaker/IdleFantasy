    <string name="boss_demon_lord_name">魔王</string>
    <string name="boss_kraken_name">クラーケン</string>
    <string name="boss_balrog_name">バルログ</string>

    <!-- ===== Pet names and descriptions ===== -->
    <string name="pet_dragon_whelp_name">ドラゴンの幼獣</string>
    <string name="pet_dragon_whelp_desc">戦闘経験値を増加させるドラゴンの子ども。</string>
    <string name="pet_imp_pet_name">インプのペット</string>
    <string name="pet_imp_pet_desc">祈りスキルの訓練効率を高めるいたずら好きなインプ。</string>
    <string name="pet_baby_kraken_name">ベビークラーケン</string>
    <string name="pet_baby_kraken_desc">調理経験値を増加させる小さなクラーケン。</string>
    <string name="pet_rock_golem_name">ロックゴーレム</string>
    <string name="pet_rock_golem_desc">採掘経験値を増加させる生きた岩石。</string>
    <string name="pet_ent_name">エント</string>
    <string name="pet_ent_desc">伐採経験値を増加させる古代の樹木の精霊。</string>
    <string name="pet_tiny_templar_name">タイニーテンプラー</string>
    <string name="pet_tiny_templar_desc">釣り経験値を増加させる小さな魚の相棒。</string>
    <string name="pet_tangleroot_name">タングルルート</string>
    <string name="pet_tangleroot_desc">農業経験値を増加させる魔法の植物クリーチャー。</string>

    <!-- Missing dungeons -->
    <string name="dungeon_collapsed_mine_name">崩落した鉱山</string>
    <string name="dungeon_collapsed_mine_desc">銅鉱山の地下に広がる巨大な空洞。がれきには洞窟トロールやロックゴーレムが巣食い、崩落したシャフトには巨大グモが巣を張っています。</string>
    <string name="dungeon_shadow_den_name">影の巣窟</string>
    <string name="dungeon_shadow_den_desc">地域のシーフギルドによって使用されている地下室のネットワーク。ならず者、暗殺者、そして影の怪物がいたる所に潜んでいます。</string>
    <string name="dungeon_abyssal_ruins_name">深淵の遺跡</string>
    <string name="dungeon_abyssal_ruins_desc">人間界の上と下の両方に同時に存在する古代の遺跡。奇妙な深淵のクリーチャーが現実世界に出没します。</string>
    <string name="dungeon_ancient_forest_ruins_name">古代の森の遺跡</string>
    <string name="dungeon_ancient_forest_ruins_desc">原始の森に飲み込まれた石造りの遺跡。現在は野生のクリーチャーやドルイドの復讐心に満ちた精霊が巣食っています。</string>
    <string name="dungeon_ancient_forge_name">古代の鍛冶場</string>
    <string name="dungeon_ancient_forge_desc">何世紀にもわたって絶えることなく燃え続けている巨大なドワーフの鍛冶場。炎のエレメンタルと鍛冶場の守護者がその秘密を守っています。</string>
    <string name="dungeon_arcane_ruins_name">アルケインの遺跡</string>
    <string name="dungeon_arcane_ruins_desc">破壊された魔術師の塔の機能的な地下室。魔法のゴーレムやエンチャントされた守護者が今も通路を巡回しています。</string>
    <string name="dungeon_corrupted_sanctum_name">堕落した聖域</string>
    <string name="dungeon_corrupted_sanctum_desc">堕落した樹冠の中心にある、影に包まれた聖域。闇の司祭と堕落した獣が古代の邪悪を守っています。</string>
    <string name="dungeon_drowned_temple_name">水没した神殿</string>
    <string name="dungeon_drowned_temple_desc">海の洞窟の下にある沈没した神殿。その広間は水で満たされ、そこを住処とする海の生物で溢れています。</string>
</resources>
