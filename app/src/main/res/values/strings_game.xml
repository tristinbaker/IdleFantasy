<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===== Level-up messages ===== -->
    <!-- Translator note: %1$d = new level number, %2$s = skill display name -->
    <string name="game_level_up">Tu as gagné un niveau ! %1$s est désormais au niveau %2$d !</string>
    <!-- Translator note: %1$s = skill display name, %2$d = new level number -->
    <string name="game_level_up_short">%1$s → %2$d</string>
    <string name="game_max_level">Niveau maximum atteint !</string>

    <!-- ===== Session result summaries ===== -->
    <string name="game_session_results_title">Résultats de la session</string>
    <!-- Translator note: %1$s = skill display name -->
    <string name="game_session_summary_header">La session %1$s est terminée</string>
    <!-- Translator note: %1$s = formatted XP amount (e.g. "1,234") -->
    <string name="game_session_xp_total">+%1$s XP gagnés</string>
    <string name="game_session_no_items">Aucun article n'a été récupéré</string>
    <string name="game_session_no_level_ups">Pas de passage au niveau supérieur pour cette session</string>
    <!-- Translator note: %1$d = number of level ups -->
    <string name="game_session_level_up_count">%1$d niveau supérieur!</string>

    <!-- ===== Combat messages ===== -->
    <!-- Translator note: %1$s = player or enemy name, %2$d = damage amount -->
    <string name="game_combat_hit">%1$s hits for %2$d damage.</string>
    <string name="game_combat_miss">%1$s misses!</string>
    <!-- Translator note: %1$s = enemy display name -->
    <string name="game_combat_enemy_defeated">%1$s defeated!</string>
    <!-- Translator note: %1$d = HP restored -->
    <string name="game_combat_food_eaten">Ate food — restored %1$d HP.</string>
    <string name="game_combat_player_died">You were defeated.</string>
    <string name="game_dungeon_cleared">Dungeon cleared!</string>
    <!-- Translator note: %1$s = dungeon display name -->
    <string name="game_dungeon_summary">%1$s complete.</string>

    <!-- ===== Farming messages ===== -->
    <!-- Translator note: %1$s = crop display name -->
    <string name="game_farming_planted">%1$s planted.</string>
    <!-- Translator note: %1$s = crop display name, %2$d = yield quantity -->
    <string name="game_farming_harvested">Harvested %2$d %1$s.</string>
    <string name="game_farming_all_harvested">Toutes les récoltes sont terminées.</string>
    <string name="game_farming_patch_cleared">Patch cleared.</string>
    <string name="game_farming_not_ready">Cette récolte n'est pas encore prête.</string>
    <!-- Translator note: %1$s = crop display name, %2$s = time remaining -->
    <string name="game_farming_ready_in">%1$s ready in %2$s.</string>

    <!-- ===== Crafting messages ===== -->
    <!-- Translator note: %1$d = quantity crafted, %2$s = item display name -->
    <string name="game_crafted">Crafted %1$d %2$s.</string>
    <!-- Translator note: %1$s = item display name -->
    <string name="game_missing_ingredient">Missing ingredient: %1$s.</string>

    <!-- ===== Shop messages ===== -->
    <!-- Translator note: %1$d = quantity, %2$s = item display name, %3$d = total cost -->
    <string name="game_shop_purchased">Bought %1$d %2$s for %3$d coins.</string>
    <!-- Translator note: %1$d = quantity, %2$s = item display name, %3$d = coins received -->
    <string name="game_shop_sold">Sold %1$d %2$s for %3$d coins.</string>

    <!-- ===== Prayer / burying ===== -->
    <!-- Translator note: %1$s = bone display name, %2$s = formatted XP gained -->
    <string name="game_bones_buried">Buried %1$s — +%2$s Prayer XP.</string>

    <!-- ===== Quest messages ===== -->
    <!-- Translator note: %1$s = quest display name -->
    <string name="game_quest_started">Quest started: %1$s</string>
    <string name="game_quest_completed">Quest complete: %1$s</string>
    <string name="game_quest_abandoned">Quest abandoned.</string>
    <!-- Translator note: %1$d = current progress, %2$d = target amount -->
    <string name="game_quest_progress">Progress: %1$d / %2$d</string>

    <!-- ===== XP gain messages (shown in session frame log) ===== -->
    <!-- Translator note: %1$s = formatted XP gained this minute -->
    <string name="game_xp_gained">+%1$s XP</string>
    <!-- Translator note: %1$s = item display name, %2$d = quantity -->
    <string name="game_item_received">+%2$d %1$s</string>

    <!-- ===== Arena messages ===== -->
    <!-- Translator note: %1$s = opponent display name -->
    <string name="game_arena_challenged">Challenged by %1$s!</string>
    <string name="game_arena_victory">Victoire!</string>
    <string name="game_arena_defeat">Défaite.</string>
    <!-- Translator note: %1$d = coins won -->
    <string name="game_arena_coins_won">%1$d or gagné.</string>

    <!-- ===== Easter egg / dig ===== -->
    <string name="game_dig_you_dig">Tu creuses la terre…</string>
    <string name="game_dig_nothing">Tu ne trouves rien d'autre que de la saleté.</string>
    <!-- Translator note: %1$s = item display name -->
    <string name="game_dig_found">You uncover a %1$s!</string>
    <!-- Translator note: %1$d = current hole depth in metres -->
    <string name="game_dig_depth">The hole is %1$d metres deep.</string>
    <string name="game_dig_cooldown">You already dug today. Come back tomorrow.</string>
</resources>
