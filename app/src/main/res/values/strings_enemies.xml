    <!-- ===== Dungeon names and descriptions ===== -->
    <string name="dungeon_imp_cavern_name">Caverna de Imps</string>
    <string name="dungeon_imp_cavern_desc">Una cueva poco profunda llena de imps traviesos. ¡Perfecta para principiantes absolutos!</string>
    <string name="dungeon_goblin_cave_name">Caverna de duendes</string>
    <string name="dungeon_goblin_cave_desc">Una cueva oscura infestada de goblins y ratas gigantes. Un buen lugar para que los nuevos aventureros entrenen.</string>
    <string name="dungeon_spider_den_name">Guarida de Arañas</string>
    <string name="dungeon_spider_den_desc">Una caverna llena de telarañas, repleta de arañas venenosas. ¡Trae antídoto!</string>
    <string name="dungeon_bandit_camp_name">Bandit Camp</string>
    <string name="dungeon_bandit_camp_desc">A hideout of thieves and rogues in the wilderness. Watch your coin purse!</string>
    <string name="dungeon_undead_crypt_name">Undead Crypt</string>
    <string name="dungeon_undead_crypt_desc">An ancient burial ground where the dead refuse to rest. Beware the dark magic!</string>
    <string name="dungeon_fortress_ruins_name">Fortress Ruins</string>
    <string name="dungeon_fortress_ruins_desc">The crumbling remains of an ancient castle, now guarded by knights and soldiers.</string>
    <string name="dungeon_orc_stronghold_name">Orc Stronghold</string>
    <string name="dungeon_orc_stronghold_desc">A fortified orc settlement deep in the mountains. Only the brave dare enter.</string>
    <string name="dungeon_volcanic_depths_name">Volcanic Depths</string>
    <string name="dungeon_volcanic_depths_desc">A scorching cavern inhabited by hellhounds and lesser demons. The heat is unbearable!</string>
    <string name="dungeon_dragon_lair_name">Dragon\'s Lair</string>
    <string name="dungeon_dragon_lair_desc">The legendary home of green dragons. Only master warriors survive this challenge.</string>
    <string name="dungeon_farm_name">Farm</string>
    <string name="dungeon_farm_desc">A peaceful farm with livestock. Great for beginners looking to gather food!</string>
    <string name="dungeon_infernal_stronghold_name">Infernal Stronghold</string>
    <string name="dungeon_infernal_stronghold_desc">A fortress of fire and brimstone, ruled by demons and hellhounds. The heat alone can kill the unprepared.</string>
    <string name="dungeon_ancient_temple_name">Ancient Temple</string>
    <string name="dungeon_ancient_temple_desc">An ancient temple guarded by the most powerful creatures in the realm. Only the strongest warriors dare enter.</string>

