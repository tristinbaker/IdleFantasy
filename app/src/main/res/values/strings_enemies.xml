    <string name="pet_baby_kraken_desc">Un tout petit kraken qui augmente votre XP de Cuisine.</string>
    <string name="pet_rock_golem_name">Golem de Pierre</string>
    <string name="pet_rock_golem_desc">Une formation rocheuse vivante qui augmente votre XP de Minage.</string>
    <string name="pet_ent_name">Ent</string>
    <string name="pet_ent_desc">Un ancien esprit d'arbre qui booste votre XP de coupe de Bois.</string>
    <string name="pet_tiny_templar_name">Petite Templier</string>
    <string name="pet_tiny_templar_desc">Un petit compagnon poisson qui augmente votre XP de Pêche.</string>
    <string name="pet_tangleroot_name">Créature végétale</string>
    <string name="pet_tangleroot_desc">Une créature végétale magique qui améliore votre XP de Ferme.</string>
