    <!-- Translator note: %1$s = skill display name, %2$d = new level number -->
    <string name="game_level_up_short">%1$s → %2$d</string>
    <string name="game_max_level">Maximales Level erreicht!</string>

    <!-- ===== Session result summaries ===== -->
    <string name="game_session_results_title">Sitzungsergebnisse</string>
    <!-- Translator note: %1$s = skill display name -->
    <string name="game_session_summary_header">%1$s Sitzung beendet</string>
    <!-- Translator note: %1$s = formatted XP amount (e.g. "1,234") -->
    <string name="game_session_xp_total">+%1$s XP verdient</string>
    <string name="game_session_no_items">Es wurden keine Gegenstände gesammelt</string>
    <string name="game_session_no_level_ups">In dieser Sitzung gab es keine Levelaufstiege</string>
    <!-- Translator note: %1$d = number of level ups -->
