    <!-- Translator note: %1$d = quantity crafted, %2$s = item display name -->
    <string name="game_crafted">%1$d %2$s hergestellt.</string>
    <!-- Translator note: %1$s = item display name -->
    <string name="game_missing_ingredient">Fehlende Zutat: %1$s.</string>

    <!-- ===== Shop messages ===== -->
    <!-- Translator note: %1$d = quantity, %2$s = item display name, %3$d = total cost -->
    <string name="game_shop_purchased">%1$d %2$s für %3$d Münzen gekauft.</string>
    <!-- Translator note: %1$d = quantity, %2$s = item display name, %3$d = coins received -->
    <string name="game_shop_sold">%1$d %2$s für %3$d Münzen verkauft.</string>

    <!-- ===== Prayer / burying ===== -->
    <!-- Translator note: %1$s = bone display name, %2$s = formatted XP gained -->
    <string name="game_bones_buried">%1$s begraben — +%2$s Gebets-XP.</string>

    <!-- ===== Quest messages ===== -->
    <!-- Translator note: %1$s = quest display name -->
    <string name="game_quest_started">Mission gestartet: %1$s</string>
    <string name="game_quest_completed">Mission abgeschlossen: %1$s</string>
    <string name="game_quest_abandoned">Mission abgebrochen.</string>
    <!-- Translator note: %1$d = current progress, %2$d = target amount -->
    <string name="game_quest_progress">Fortschritt: %1$d / %2$d</string>

