    <string name="game_dig_you_dig">Du gräbst in der Erde…</string>
    <string name="game_dig_nothing">Du findest nichts als Dreck.</string>
    <!-- Translator note: %1$s = item display name -->
    <string name="game_dig_found">Du entdeckst ein %1$s!</string>
    <!-- Translator note: %1$d = current hole depth in metres -->
    <string name="game_dig_depth">Das Loch ist %1$d Meter tief.</string>
    <string name="game_dig_cooldown">Du hast heute schon gegraben. Komm morgen wieder.</string>
