    <!-- Translator note: %1$s = formatted XP gained this minute -->
    <string name="game_xp_gained">+%1$s XP</string>
    <!-- Translator note: %1$s = item display name, %2$d = quantity -->
    <string name="game_item_received">+%2$d %1$s</string>

