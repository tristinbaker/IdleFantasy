    <!-- ===== Combat messages ===== -->
    <!-- Translator note: %1$s = player or enemy name, %2$d = damage amount -->
    <string name="game_combat_hit">%1$s hat %2$d Schaden erhalten.</string>
    <string name="game_combat_miss">%1$s verfehlt!</string>
    <!-- Translator note: %1$s = enemy display name -->
    <string name="game_combat_enemy_defeated">%1$s besiegt!</string>
    <!-- Translator note: %1$d = HP restored -->
    <string name="game_combat_food_eaten">Gegessen —  %1$d HP wiederhergestellt.</string>
    <string name="game_combat_player_died">Du wurdest besiegt.</string>
    <string name="game_dungeon_cleared">Dungeon abgeschlossen!</string>
    <!-- Translator note: %1$s = dungeon display name -->
    <string name="game_dungeon_summary">%1$s vollständig.</string>

    <!-- ===== Farming messages ===== -->
    <!-- Translator note: %1$s = crop display name -->
    <string name="game_farming_planted">%1$s gepflanzt.</string>
    <!-- Translator note: %1$s = crop display name, %2$d = yield quantity -->
    <string name="game_farming_harvested">%2$d %1$s geerntet .</string>
    <string name="game_farming_all_harvested">Alle reifen Pflanzen sind geerntet.</string>
    <string name="game_farming_patch_cleared">Beet freigegeben.</string>
    <string name="game_farming_not_ready">Diese Ernte ist noch nicht reif.</string>
    <!-- Translator note: %1$s = crop display name, %2$s = time remaining -->
    <string name="game_farming_ready_in">%1$s ist fertig in %2$s.</string>

