    <!-- ===== Dungeon names and descriptions ===== -->
    <string name="dungeon_imp_cavern_name">Caverna di Imp</string>
    <string name="dungeon_imp_cavern_desc">Una caverna poco profonda piena di imp dispettosi. Perfetta per assoluti principianti!</string>
    <string name="dungeon_goblin_cave_name">Caverna di Goblin</string>
    <string name="dungeon_goblin_cave_desc">Una caverna oscura infestata da goblin e ratti giganti. On buon posto per l\'addestramento per nuovi avventurieri.</string>
    <string name="dungeon_spider_den_name">Tana di Ragni</string>
    <string name="dungeon_spider_den_desc">Una caverna piena di ragnatele, abitata da ragni velenosi. Porta con te un antidoto!</string>
    <string name="dungeon_bandit_camp_name">Accampamento di Banditi</string>
    <string name="dungeon_bandit_camp_desc">Un nascondiglio di ladri e delinquenti nella natura. Tieni una mano sul tuo portamonete!</string>
    <string name="dungeon_undead_crypt_name">Cripta di Non Morti</string>
    <string name="dungeon_undead_crypt_desc">Un antico cimitero dove i morti si rifiutano di stare a riposo. Fai attenzione alla magia oscura!</string>
    <string name="dungeon_fortress_ruins_name">Fortezza in Rovina</string>
    <string name="dungeon_fortress_ruins_desc">I resti fatiscenti di un antico castello, ora custoditi da cavalieri e soldati.</string>
    <string name="dungeon_orc_stronghold_name">Fortificazione degli Orchi</string>
    <string name="dungeon_orc_stronghold_desc">Un accampamento fortificato di orchi nelle profondità delle montagne. Solo i coraggiosi osano entrare.</string>
    <string name="dungeon_volcanic_depths_name">Profondità Vulcaniche</string>
    <string name="dungeon_volcanic_depths_desc">Una caverna rovente abitata da segugi infernali e demoni minori. Il calore è insopportabile!</string>
    <string name="dungeon_dragon_lair_name">Covo di Draghi</string>
    <string name="dungeon_dragon_lair_desc">La leggendaria casa dei draghi verdi. Solo i maestri guerrieri sopravvivono a questa sfida.</string>
    <string name="dungeon_farm_name">Fattoria</string>
    <string name="dungeon_farm_desc">Una tranquilla fattoria con animali da allevamento. Ottima per principianti alla ricerca di cibo!</string>
    <string name="dungeon_infernal_stronghold_name">Forte Infernale</string>
    <string name="dungeon_infernal_stronghold_desc">Una fortezza di fuoco e zolfo, governata da demoni e segugi infernali. Il solo calore è sufficiente per uccidere gli impreparati.</string>
    <string name="dungeon_ancient_temple_name">Antico Tempio</string>
    <string name="dungeon_ancient_temple_desc">Un antico tempio custodito dalle più potenti creature del regno. Solo i più forti guerrieri osano entrare.</string>

