    <string name="pet_imp_pet_name">Imp da Compagnia</string>
    <string name="pet_imp_pet_desc">Un imp dispettoso che potenzia il tuo addestramento in Preghiera.</string>
    <string name="pet_baby_kraken_name">Piccolo Kraken</string>
    <string name="pet_baby_kraken_desc">Un minuscolo kraken che migliora i tuoi XP in Cucina.</string>
    <string name="pet_rock_golem_name">Golem di Pietra</string>
    <string name="pet_rock_golem_desc">Una formazione rocciosa viva che migliora i tuoi XP in Miniera.</string>
    <string name="pet_ent_name">Ent</string>
    <string name="pet_ent_desc">Lo spirito di un albero antico che potenzia i tuoi XP in Taglialegna.</string>
    <string name="pet_tiny_templar_name">Piccolo Templare</string>
    <string name="pet_tiny_templar_desc">Un piccolo pesce da compagnia che potenzia i tuoi XP in Pesca.</string>
    <string name="pet_tangleroot_name">Radice Annodata</string>
    <string name="pet_tangleroot_desc">Una creatura magica vegetale che migliora i tuoi XP in Agricoltura.</string>
